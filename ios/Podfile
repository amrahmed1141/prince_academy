platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  strip_bad_g_tokens = lambda do |flags|
    return flags if flags.nil?

    arr = flags.is_a?(String) ? flags.split(/\s+/) : Array(flags)
    arr.reject! do |flag|
      clean_flag = flag.to_s.strip.gsub(/\A['"]|['"]\z/, '')
      clean_flag == '-G' || clean_flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS'
    end

    flags.is_a?(String) ? arr.join(' ') : arr
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # 1) Force all pods to iOS 14
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'

      # 2) Remove ONLY standalone '-G' from target-level flags
      if ['BoringSSL-GRPC', 'gRPC-C++', 'gRPC-Core', 'grpc'].include?(target.name)
        %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS].each do |key|
          config.build_settings[key] = strip_bad_g_tokens.call(config.build_settings[key])
        end
      end
    end

    # 3) Remove ONLY standalone '-G' from per-file COMPILER_FLAGS in Pods.xcodeproj
    if ['BoringSSL-GRPC', 'gRPC-C++', 'gRPC-Core', 'grpc'].include?(target.name)
      target.source_build_phase.files.each do |file|
        next unless file.settings && file.settings['COMPILER_FLAGS']

        file.settings['COMPILER_FLAGS'] = strip_bad_g_tokens.call(file.settings['COMPILER_FLAGS'])
      end
    end
  end

  # 4) Remove ONLY standalone '-G' from generated CocoaPods xcconfig files
  Dir.glob(File.join(__dir__, 'Pods', 'Target Support Files', '**', '*.xcconfig')).each do |path|
    content = File.read(path)
    patched = content
      .gsub(/([ \t])\-G(?=[ \t]|$)/, '\1')
      .gsub(/\=\-G(?=[ \t]|$)/, '=')
      .gsub(/([ \t])\-GCC_WARN_INHIBIT_ALL_WARNINGS(?=[ \t]|$)/, '\1')
      .gsub(/\=\-GCC_WARN_INHIBIT_ALL_WARNINGS(?=[ \t]|$)/, '=')
    File.write(path, patched) if patched != content
  end

  # 5) Xcode 26 clang rejects this gRPC 1.62 construct on Intel simulator.
  grpc_basic_seq = File.join(__dir__, 'Pods', 'gRPC-Core', 'src', 'core', 'lib', 'promise', 'detail', 'basic_seq.h')
  if File.exist?(grpc_basic_seq)
    File.chmod(0o644, grpc_basic_seq)
    content = File.read(grpc_basic_seq)
    patched = content.gsub('Traits::template CallSeqFactory(', 'Traits::CallSeqFactory(')
    File.write(grpc_basic_seq, patched) if patched != content
  end
end